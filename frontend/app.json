{
  "expo": {
    "name": "Физика AI",
    "slug": "physics-ai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "physics-ai",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.physicsai.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Нужно для сканирования QR-кода подключения.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#6C63FF"
      },
      "softwareKeyboardLayoutMode": "resize",
      "permissions": [
        "CAMERA"
      ],
      "package": "com.physicsai.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "react-native-google-mobile-ads",
        {
          "androidAppId": "ca-app-pub-4380583516308857~8132939796",
          "iosAppId": "ca-app-pub-4380583516308857~4332762758"
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#6C63FF",
          "defaultChannel": "default"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "0f5d864b-9c41-42d1-b161-6a29613030ae"
      }
    }
  }
}
